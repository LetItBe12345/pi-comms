{
  "name": "pi-comms",
  "version": "0.1.0",
  "private": true,
  "description": "Local multi-session communication extension for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent-communication"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.19 <23"
  },
  "packageManager": "npm@10.9.8",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LetItBe12345/pi-comms.git"
  },
  "bugs": {
    "url": "https://github.com/LetItBe12345/pi-comms/issues"
  },
  "homepage": "https://github.com/LetItBe12345/pi-comms#readme",
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "scripts": {
    "broker": "tsx src/broker/server.ts",
    "broker:migrate": "tsx src/extension/broker-process.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "check": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "tsx": "^4.23.1"
  }
}
